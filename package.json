{
  "name": "n8n-nodes-acrelens",
  "version": "0.1.0",
  "description": "n8n community node for AcreLens — the B2B land-intelligence API. Run land analyses (off-grid / rural-residential / recreational / investment) on US property and receive completed reports via webhook.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "acrelens",
    "land",
    "real-estate",
    "gis",
    "off-grid"
  ],
  "license": "MIT",
  "homepage": "https://www.acrelens.com",
  "author": {
    "name": "AcreLens",
    "email": "support@acrelens.com",
    "url": "https://www.acrelens.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hakeemwarner95/n8n-nodes-acrelens.git"
  },
  "engines": {
    "node": ">=20.15"
  },
  "main": "index.js",
  "scripts": {
    "build": "npx rimraf dist && tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build && npm run lint -s"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/AcreLensApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/AcreLens/AcreLens.node.js",
      "dist/nodes/AcreLens/AcreLensTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@typescript-eslint/parser": "~7.15",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "gulp": "^4.0.2",
    "n8n-workflow": "*",
    "prettier": "^3.3.2",
    "rimraf": "^5.0.5",
    "typescript": "^5.5.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
